ELEVENLABS_API_KEY=
GEMINI_API_KEY=
# Primary model when GEMINI_SOAP_MODEL / GEMINI_CHART_MODEL are unset. Code default if unset: gemini-2.5-flash-lite.
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_SOAP_MODEL=
# GEMINI_CHART_MODEL=
# Optional: floating medical chat (Tavily) on dashboard + recorder
TAVILY_API_KEY=
PORT=5179
# Optional: GlassesStream / similar — use the viewer page URL (e.g. http://IP:8787/); the server maps "/" to "/stream" (MJPEG).
# Or set the raw stream URL directly, e.g. http://192.168.1.195:8787/stream
# GLASSES_STREAM_URL=http://192.168.1.195:8787/
